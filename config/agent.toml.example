# Commando Agent Configuration
# Copy to /etc/commando/agent.toml and set chmod 600 root:root

bind = "10.0.0.5"         # Bind to LAN interface (not 0.0.0.0)
port = 9876
shell = "sh"               # or "bash", "fish"
psk = "REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32"
max_output_bytes = 131072  # 128KB, tail-truncate beyond this
max_concurrent = 8         # Max simultaneous exec calls
